.vscode/launch.json

# ----- OS Files -----
Thumbs.db
ehthumbs.db
Desktop.ini
.DS_Store

# ----- Logs -----
*.log
logs/

# ----- Misc -----
*.bak
*.zip
*.tar.gz
*.rar
