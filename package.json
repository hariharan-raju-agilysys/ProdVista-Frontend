{
  "name": "prodvista-dashboard",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "predev": "npx --yes kill-port 5173 5174 5175 5176 --silent || true",
    "dev": "vite --port 5173 --strictPort",
