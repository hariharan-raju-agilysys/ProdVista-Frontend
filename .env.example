# ===========================================================================
# ProdVista Frontend Environment Variables
# Copy this file to .env.development or .env.production and fill values
# ===========================================================================

# Azure AD / Microsoft Entra ID Configuration
# Get these values from your Azure AD App Registration in the Azure Portal

# Application (client) ID from Azure AD App Registration
VITE_AZURE_CLIENT_ID=your-client-id-here

# Directory (tenant) ID - use 'common' for multi-tenant, or your specific tenant ID
VITE_AZURE_TENANT_ID=common

# Redirect URI - must match what's configured in Azure AD App Registration
VITE_REDIRECT_URI=http://localhost:5173

# API Base Path - the path prefix for all API calls
# In dev: '/api' (Vite proxy forwards to localhost:5555)
# In prod: '/prodvista/api' (Istio VirtualService routes with rewrite)
VITE_API_BASE_PATH=/api

# API Base URL (your backend) - leave empty for same-origin deployment
VITE_API_URL=

# API request timeout in milliseconds (default: 30000)
VITE_API_TIMEOUT=30000

# Application title shown in browser tab
VITE_APP_TITLE=ProdVista Dashboard

# Enable React DevTools overlay (true in dev, false in prod)
VITE_ENABLE_DEVTOOLS=true
